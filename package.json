{
  "name": "wikijs-mcp",
  "version": "2.4.0",
  "description": "MCP Server providing read-only Wiki.js page access via GraphQL",
  "main": "dist/server.js",
  "homepage": "https://github.com/heAdz0r/wikijs-mcp-server",
  "repository": {
    "type": "git",
    "url": "https://github.com/heAdz0r/wikijs-mcp-server.git"
  },
  "bugs": {
    "url": "https://github.com/heAdz0r/wikijs-mcp-server/issues"
  },
  "scripts": {
    "setup": "./scripts/setup.sh",
    "start": "./scripts/start_http.sh",
    "stop": "./scripts/stop_server.sh",
    "start:http": "./scripts/start_http.sh",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke.test.ts",
    "test:watch": "vitest",
    "dev": "nodemon --exec tsx src/server.ts",
    "build": "tsc"
  },
  "keywords": [
    "wikijs",
    "wiki.js",
    "graphql",
    "mcp",
    "model-context-protocol",
    "api",
    "anthropic",
    "llm",
    "ai-tools"
  ],
  "author": "Anonymous",
  "license": "MIT",
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/",
    "src/",
    "scripts/",
    "*.md",
    "example.env",
    "tsconfig.json"
  ],
  "dependencies": {
    "@fastify/formbody": "^7.4.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^16.5.0",
    "fastify": "^4.27.2",
    "fastify-plugin": "^4.5.1",
    "graphql": "^16.8.1",
    "graphql-request": "^6.1.0",
    "jose": "^6.2.2",
    "uuid": "^13.0.0",
    "zod": "^3.25.17"
  },
  "devDependencies": {
    "@types/node": "^20.11.19",
    "@types/uuid": "^10.0.0",
    "nodemon": "^3.0.3",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.3.3",
    "vitest": "^4.1.1"
  },
  "type": "module"
}
